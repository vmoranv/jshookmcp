{
  "name": "@jshookmcp/extension-sdk",
  "version": "0.3.1",
  "description": "SDK for developing jshookmcp plugins and workflows",
  "license": "AGPL-3.0-only",
  "author": {
    "name": "vmoranv",
    "url": "https://github.com/vmoranv"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vmoranv/jshookmcp.git",
    "directory": "packages/extension-sdk"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    },
    "./workflow": {
      "types": "./dist/workflow.d.ts",
      "default": "./dist/workflow.js"
    },
    "./bridges": {
      "types": "./dist/bridges/index.d.ts",
      "default": "./dist/bridges/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "clean": "node ../../scripts/clean-dist.mjs",
    "build": "pnpm run clean && tsc -p tsconfig.json && tsc-alias -p tsconfig.json --resolve-full-paths",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
