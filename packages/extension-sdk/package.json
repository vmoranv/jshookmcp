{
  "name": "@jshookmcp/extension-sdk",
  "version": "0.3.1",
  "description": "SDK for developing jshookmcp plugins and workflows",
  "license": "AGPL-3.0-only",
  "author": {
    "name": "vmoranv",
    "url": "https://github.com/vmoranv"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vmoranv/jshookmcp.git",
    "directory": "packages/extension-sdk"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    "./workflow": {
      "types": "./dist/workflow.d.mts",
      "default": "./dist/workflow.mjs"
    },
    "./bridges": {
      "types": "./dist/bridges/index.d.mts",
      "default": "./dist/bridges/index.mjs"
    },
    "./plugin": {
      "types": "./dist/plugin.d.mts",
      "default": "./dist/plugin.mjs"
    },
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "clean": "node ../../scripts/clean-dist.mjs",
    "build": "pnpm run clean && tsdown",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
