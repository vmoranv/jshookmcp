{
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "off",
    "nursery": "off"
  },
  "rules": {
    "no-unused-vars": "error",
    "no-underscore-dangle": [
      "error",
      {
        "allow": [
          "__activated",
          "__aiHookMetadata",
          "__aiHooks",
          "__autocomplete",
          "__bridgeResults",
          "__canvasMock",
          "__capturedAPIs",
          "__cdpTimingOffset",
          "__close",
          "__config",
          "__domObserver",
          "__error__",
          "__fetchInterceptorInjected",
          "__fetchRequests",
          "__functionTracer",
          "__getFetchRequests",
          "__getXHRRequests",
          "__handler",
          "__jshookElectronCompatPatched",
          "__jshookSSEMonitor",
          "__launchOptions",
          "__modeConfig",
          "__more",
          "__networkRequests",
          "__order",
          "__parsedMeta",
          "__pluginCtx",
          "__pwOriginalFetch",
          "__pwOriginalXMLHttpRequest",
          "__registered",
          "__registrations",
          "__rolledBack",
          "__scratchpad",
          "__scriptReplacePersistRules",
          "__truncated__",
          "__truncatedKeys",
          "__turnstile_callbacks",
          "__type",
          "__wasmInstances",
          "__wasmModuleStorage",
          "__workerUrls",
          "__xhrInterceptorInjected",
          "__xhrRequests",
          "_allToolsByName",
          "_body",
          "_bodyUnavailable",
          "_emit",
          "_enumerateModules",
          "_executionMetrics",
          "_headers",
          "_id",
          "_listeners",
          "_meta",
          "_nextStepHint",
          "_note",
          "_process",
          "_raw_summary",
          "_requestId",
          "_resolveFilename",
          "_result",
          "_session",
          "_status",
          "_tabContext",
          "_wsConfig",
          "_wsConnections",
          "_wsFrameOrder",
          "_wsFramesByRequest",
          "_wsListeners",
          "_wsSession"
        ]
      }
    ],
    "prefer-const": "error",
    "eqeqeq": "error",
    "no-constant-condition": "error",
    "unicorn/require-post-message-target-origin": "off"
  },
  "plugins": ["unicorn", "import", "typescript"],
  "ignorePatterns": ["dist/**", "node_modules/**"]
}
