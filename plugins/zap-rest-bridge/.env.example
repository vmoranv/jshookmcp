# OWASP ZAP REST API bridge plugin
# Copy to .env in this directory and adjust values.

# ZAP API base URL (loopback only)
ZAP_API_URL=http://127.0.0.1:8080

# API key configured in ZAP (Options -> API -> API key)
# If your ZAP is configured to allow access without API key, this can be left empty.
ZAP_API_KEY=replace-with-your-zap-api-key

