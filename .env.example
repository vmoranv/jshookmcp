# jshookmcp runtime overrides
#
# Copy to `.env` only when you need to override built-in defaults.
# If a key is omitted, runtime falls back to the defaults in `src/utils/config.ts`.

# ── Browser / Puppeteer ────────────────────────────────────────────────
PUPPETEER_EXECUTABLE_PATH=
CHROME_PATH=
BROWSER_EXECUTABLE_PATH=
# PUPPETEER_HEADLESS=true
# PUPPETEER_TIMEOUT=30000

# ── Runtime paths (customize only if you want non-default locations) ──
MCP_SCREENSHOT_DIR=screenshots
CAPTCHA_SCREENSHOT_DIR=screenshots/captcha
MCP_DEBUGGER_SESSIONS_DIR=debugger-sessions
MCP_EXTENSION_REGISTRY_DIR=artifacts/extension-registry
MCP_TLS_KEYLOG_DIR=artifacts/tmp
MCP_REGISTRY_CACHE_DIR=.jshookmcp/cache

# ── Transport / auth ───────────────────────────────────────────────────
# MCP_TRANSPORT=stdio
# MCP_HOST=127.0.0.1
# MCP_PORT=3000
MCP_AUTH_TOKEN=

# ── Extension / workflow discovery ─────────────────────────────────────
EXTENSION_REGISTRY_BASE_URL=https://raw.githubusercontent.com/vmoranv/jshookmcpextension/master/registry
MCP_PLUGIN_ROOTS=
MCP_WORKFLOW_ROOTS=
MCP_PLUGIN_ALLOWED_DIGESTS=

# ── External bridges / services ────────────────────────────────────────
CAPTCHA_PROVIDER=
CAPTCHA_API_KEY=
CAPTCHA_SOLVER_BASE_URL=
BURP_MCP_SSE_URL=
BURP_MCP_AUTH_TOKEN=
ZAP_API_URL=
ZAP_API_KEY=
GHIDRA_BRIDGE_URL=http://127.0.0.1:18080
IDA_BRIDGE_URL=http://127.0.0.1:18081

# ── Optional performance / cache overrides ─────────────────────────────
# ENABLE_CACHE=true
# CACHE_DIR=.cache
# CACHE_TTL=3600
# MAX_CONCURRENT_ANALYSIS=3
# MAX_CODE_SIZE_MB=10

# ── Optional search overrides ──────────────────────────────────────────
# SEARCH_QUERY_CATEGORY_PROFILES_JSON=[]
# SEARCH_CJK_QUERY_ALIASES_JSON=[]
# SEARCH_INTENT_TOOL_BOOST_RULES_JSON=[]

# ── Test runner only (not read by runtime) ─────────────────────────────
# `pnpm test` already computes workers from current idle CPU.
# Uncomment only if you want to force a local ceiling/floor.
# VITEST_MAX_WORKERS=4
# VITEST_MAX_WORKERS_CAP=8
# VITEST_MIN_WORKERS=1
# VITEST_IDLE_RESOURCE_TARGET=0.8
# VITEST_CPU_SAMPLE_MS=750
