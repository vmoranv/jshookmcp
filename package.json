{
  "name": "@jshookmcp/jshook",
  "version": "0.1.4",
  "packageManager": "pnpm@10.28.2",
  "description": "MCP server with 242 built-in tools (234 domain tools across 16 domains) for AI-assisted JavaScript analysis and security analysis — browser automation, CDP debugging, network monitoring, JS hooks, code analysis, and workflow orchestration",
  "mcpName": "io.github.vmoranv/jshookmcp",
  "main": "dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "src/native/scripts"
  ],
  "bin": {
    "jshook": "dist/index.js",
    "jshookmcp": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vmoranv/jshookmcp.git"
  },
  "bugs": {
    "url": "https://github.com/vmoranv/jshookmcp/issues"
  },
  "homepage": "https://github.com/vmoranv/jshookmcp#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.json && tsc-alias -p tsconfig.json --resolve-full-paths && pnpm -C packages/extension-sdk build && node scripts/copy-native-scripts.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && pnpm -C packages/extension-sdk typecheck",
    "dev": "tsx --conditions=development watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "prepack": "pnpm run build",
    "audit:tools": "node scripts/audit-tools.mjs",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "package": "pnpm pack",
    "prepublishOnly": "pnpm run check",
    "install:full": "pnpm install && pnpm exec camoufox-js fetch"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "javascript",
    "javascript-analysis",
    "security-analysis",
    "hook",
    "hooking",
    "deobfuscation",
    "ai",
    "claude",
    "puppeteer",
    "chrome-devtools",
    "debugger",
    "web-scraping",
    "anti-detection",
    "captcha",
    "browser-automation",
    "network-monitoring",
    "ast",
    "obfuscation",
    "cryptography-detection",
    "code-analysis"
  ],
  "author": {
    "name": "vmoranv",
    "url": "https://github.com/vmoranv"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "koffi": "^2.15.1",
    "openai": "^6.25.0",
    "ora": "^9.3.0",
    "rebrowser-puppeteer-core": "^24.8.1",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "camoufox-js": "^0.9.1",
    "playwright-core": "^1.58.2"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^25.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
